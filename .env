# API Configuration
# Relative path — proxied to the Render backend by the Vite dev server
# (vite.config.ts) locally, and by vercel.json's rewrite in production.
# This keeps every API call same-origin from the browser's perspective,
# so the backend's CORS config never comes into play.
VITE_API_BASE_URL=/api

# App Configuration
VITE_APP_NAME=Portfolio
VITE_APP_ENV=development
